generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Native PostgreSQL enums
// ---------------------------------------------------------------------------

enum Role {
  superadmin
  admin
  marketing
  // Follow-up team member. Logs into the separate /employee portal (NOT
  // /admin). Sees only leads explicitly assigned to them via
  // Enrollment.assigned_to. Permissions are seeded under role_permissions.
  employee
  // Public self-enrolled students. Holds NO admin permissions — can
  // authenticate but is locked out of every admin-console route.
  student
}

enum EnrollmentStatus {
  submitted
  payment_pending
  sync_pending
  paid
  completed
  failed
  expired
}

enum ExternalApiStatus {
  pending
  processing
  success
  failed
  retrying
  dead_letter
}

enum PaymentStatus {
  initiated
  pending
  success
  failed
  cancelled
  expired
  refunded
}

// Outcome of an outbound transactional email send (onboarding, etc.).
enum EmailStatus {
  sent     // SMTP accepted the message
  failed   // send attempt(s) errored
  skipped  // not sent on purpose (mail disabled, or account already existed)
}

enum FollowupStatus {
  // Original 8 values — preserved for backward compatibility with any
  // existing followup rows. Do not remove or reorder.
  payment_pending
  call_back_later
  interested
  not_interested
  payment_completed
  followup_closed
  invalid_number
  no_response
  // Employee-portal additions. The portal-facing status set is:
  //   new, contacted, followup_scheduled, interested, not_interested,
  //   payment_pending, payment_completed, converted, lost, closed.
  // Existing values map naturally; `followup_closed` and `closed` are
  // synonymous and either is accepted by the API (the UI displays "Closed").
  new
  contacted
  followup_scheduled
  converted
  lost
  closed
}

// Phase 3A: new enums for public enrollment form
enum EnrollmentUserRole {
  STUDENT
  FRESH_GRADUATE
  WORKING_PROFESSIONAL
  CAREER_SWITCHER
}

enum EducationLevel {
  SCHOOL
  JR_COLLEGE
  UNDERGRADUATE
  GRADUATE
  POST_GRADUATE
  DOCTORATE
  OTHER
}

enum Readiness {
  BEGINNER
  INTERMEDIATE
  READY_FOR_INTERVIEW
}

enum EnrollmentSource {
  SOCIAL_MEDIA
  COLLEGE
  FRIEND
  GOOGLE
  OTHER
}

// Marks where the enrollment originated:
//   - INTERNAL: admin manual + bulk CSV (admin-driven)
//   - EXTERNAL: public website "Enroll Now" flow
enum CandidateType {
  INTERNAL
  EXTERNAL
}

enum CourseStatus {
  ACTIVE
  INACTIVE
}

enum MasterStatus {
  ACTIVE
  INACTIVE
}

enum PlanTier {
  SILVER
  GOLD
  PLATINUM
}

enum PlanStatus {
  ACTIVE
  INACTIVE
}

enum InternalPlanDuration {
  ONE_MONTH    @map("1_MONTH")
  THREE_MONTHS @map("3_MONTHS")
  SIX_MONTHS   @map("6_MONTHS")
  TWELVE_MONTHS @map("12_MONTHS")
}

enum InternalPlanStatus {
  ACTIVE
  INACTIVE
}

// Payment status for the admin-internal enrollment flow ONLY.
// Public-website enrollments leave this NULL and rely on the existing
// EnrollmentStatus enum + Payment rows. Stored as its own column so the
// admin list page can filter on it without a CASE expression.
enum InternalPaymentStatus {
  PENDING          // no money collected yet
  PARTIAL          // amount_paid < final_amount, but > 0
  PAID             // amount_paid >= final_amount, final > 0
  FULLY_DISCOUNTED // final_amount = 0 because coupon zeroed it out
}

// Third-party sync state, separate from the customer-facing payment
// lifecycle (EnrollmentStatus). Lives on the enrollment so a single row
// makes it clear whether OUR webhook to Sumago / EXTERNAL_API_URL
// succeeded, even if the customer's payment itself is paid.
enum ExternalSyncStatus {
  PENDING      // queued or in-flight
  SUCCESS      // third-party returned 2xx
  FAILED       // an attempt failed; retry loop is still active
  DEAD_LETTER  // retries exhausted; needs manual retry-sync
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  role          Role      @default(admin)
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @updatedAt @db.Timestamptz
  deleted_at    DateTime? @db.Timestamptz

  refresh_tokens          RefreshToken[]
  assigned_followups      Followup[]     @relation("AssignedFollowups")
  authored_followup_notes FollowupNote[] @relation("AuthoredFollowupNotes")
  audit_logs              AuditLog[]     @relation("ActorAuditLogs")
  assigned_enrollments    Enrollment[]   @relation("AssignedEnrollments")

  @@index([email])
  @@map("users")
}

model RefreshToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @db.VarChar(255)
  family_id  String    @db.Uuid
  revoked_at DateTime? @db.Timestamptz
  expires_at DateTime  @db.Timestamptz
  created_at DateTime  @default(now()) @db.Timestamptz

  user User @relation(fields: [user_id], references: [id], onDelete: Restrict)

  @@index([user_id])
  @@index([token_hash])
  @@map("refresh_tokens")
}

model Enrollment {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Legacy fields — nullable for new-shape enrollments
  first_name      String?             @db.VarChar(100)
  last_name       String?             @db.VarChar(100)
  email           String              @db.VarChar(255)
  phone_number    String?             @db.VarChar(20)
  plan            String?             @db.VarChar(100)
  group           String?             @db.VarChar(100)
  unit            String?             @db.VarChar(100)
  phase           String?             @db.VarChar(100)
  segment         String?             @db.VarChar(100)
  amount          Int?
  status          EnrollmentStatus    @default(submitted)
  created_at      DateTime            @default(now()) @db.Timestamptz
  updated_at      DateTime            @updatedAt @db.Timestamptz
  deleted_at      DateTime?           @db.Timestamptz

  // Phase 3A: new columns for frontend enrollment form
  name            String?             @db.VarChar(200)
  enrollment_code String?             @unique @db.VarChar(40)
  user_role       EnrollmentUserRole?
  education       EducationLevel?
  readiness       Readiness?
  source          EnrollmentSource?
  promo_code      String?             @db.VarChar(50)
  // Origin marker — INTERNAL for admin manual/bulk, EXTERNAL for public website.
  // Defaults to EXTERNAL so any future caller that forgets to set it doesn't
  // accidentally mark a record as INTERNAL.
  candidate_type  CandidateType?      @default(EXTERNAL)

  plan_pricing_id Int?
  plan_pricing    PlanPricing? @relation("EnrollmentPlanPricing", fields: [plan_pricing_id], references: [id], onDelete: SetNull)

  // --------------------------------------------------------------------
  // Admin-internal enrollment financial snapshot. All nullable so public
  // website rows stay valid. See createInternalEnrollment for write path.
  // coupon_snapshot freezes the coupon row at redemption time so future
  // admin edits to the plan's coupons[] never rewrite history.
  // --------------------------------------------------------------------
  internal_plan_id        Int?
  internal_plan           InternalPlan? @relation("EnrollmentInternalPlan", fields: [internal_plan_id], references: [id], onDelete: SetNull)
  base_price_paise        Int?
  discount_amount_paise   Int?
  final_amount_paise      Int?
  amount_paid_paise       Int       @default(0)
  coupon_code_snapshot    String?   @db.VarChar(50)
  coupon_snapshot         Json?
  internal_payment_status InternalPaymentStatus?

  // Third-party sync state — distinct from `status` so admin UI shows
  // payment lifecycle vs sync state separately. See ExternalSyncStatus enum.
  external_sync_status    ExternalSyncStatus?  @map("external_sync_status")

  // Employee-portal ownership. Nullable FK to users.id — set when admin
  // assigns this lead to a follow-up employee. ON DELETE SET NULL so a
  // deleted employee doesn't cascade-delete their leads. The DB layer
  // also has partial indexes on (assigned_to) and (assigned_to, status)
  // for fast "my leads" queries — see migration 20260604000000.
  assigned_to        String?     @db.Uuid
  assignee           User?       @relation("AssignedEnrollments", fields: [assigned_to], references: [id], onDelete: SetNull)

  payments           Payment[]
  external_api_logs  ExternalApiLog[]
  followups          Followup[]

  @@index([email, phone_number])
  @@index([status])
  @@index([created_at])
  @@index([enrollment_code])
  @@index([internal_plan_id])
  @@index([internal_payment_status, created_at(sort: Desc)])
  @@map("enrollments")
}

model Payment {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollment_id        String               @db.Uuid
  razorpay_order_id    String               @unique @db.VarChar(255)
  razorpay_payment_id  String?              @db.VarChar(255)
  razorpay_signature   String?              @db.VarChar(512)
  amount               Int
  currency             String               @default("INR") @db.VarChar(10)
  status               PaymentStatus        @default(initiated)
  razorpay_config_id   String?              @db.Uuid
  created_at           DateTime             @default(now()) @db.Timestamptz
  updated_at           DateTime             @updatedAt @db.Timestamptz

  enrollment         Enrollment            @relation(fields: [enrollment_id], references: [id], onDelete: Restrict)
  razorpay_config    RazorpayConfiguration? @relation(fields: [razorpay_config_id], references: [id], onDelete: SetNull)

  @@index([enrollment_id, status])
  @@map("payments")
}

model RazorpayConfiguration {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key_id                  String   @db.VarChar(255)
  key_secret_encrypted    String   @db.Text
  webhook_secret_encrypted String  @db.Text
  is_active               Boolean  @default(false)
  created_at              DateTime @default(now()) @db.Timestamptz
  updated_at              DateTime @updatedAt @db.Timestamptz

  payments Payment[]

  @@index([is_active])
  @@map("razorpay_configurations")
}

model ExternalApiLog {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollment_id   String            @db.Uuid
  payment_id      String?           @db.Uuid
  endpoint        String            @db.VarChar(500)
  request_body    Json
  response_body   Json?
  status_code     Int?
  status          ExternalApiStatus @default(pending)
  attempts        Int               @default(0)
  last_error      String?           @db.Text
  duration_ms     Int?
  next_attempt_at DateTime?         @db.Timestamptz
  created_at      DateTime          @default(now()) @db.Timestamptz
  updated_at      DateTime          @updatedAt @db.Timestamptz

  enrollment Enrollment @relation(fields: [enrollment_id], references: [id], onDelete: Restrict)

  @@index([enrollment_id, status])
  @@index([status, next_attempt_at])
  @@map("external_api_logs")
}

model WebhookEvent {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id     String    @unique @db.VarChar(255)
  event_type   String    @db.VarChar(100)
  payload      Json
  signature    String    @db.VarChar(512)
  processed    Boolean   @default(false)
  attempts     Int       @default(0)
  created_at   DateTime  @default(now()) @db.Timestamptz
  processed_at DateTime? @db.Timestamptz

  @@index([processed])
  @@map("webhook_events")
}

model Followup {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollment_id      String         @db.Uuid
  status             FollowupStatus @default(payment_pending)
  reason             String?        @db.VarChar(255)
  assigned_to        String?        @db.Uuid
  next_followup_date DateTime?      @db.Timestamptz
  closed_at          DateTime?      @db.Timestamptz
  created_at         DateTime       @default(now()) @db.Timestamptz
  updated_at         DateTime       @updatedAt @db.Timestamptz
  deleted_at         DateTime?      @db.Timestamptz

  enrollment Enrollment   @relation(fields: [enrollment_id], references: [id], onDelete: Restrict)
  assignee   User?        @relation("AssignedFollowups", fields: [assigned_to], references: [id], onDelete: SetNull)
  notes      FollowupNote[]

  @@index([enrollment_id])
  @@index([assigned_to, status, next_followup_date])
  @@index([status])
  @@map("followups")
}

model AuditLog {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_id     String?   @db.Uuid
  actor_email  String?   @db.VarChar(255)
  action       String    @db.VarChar(100)
  entity_type  String    @db.VarChar(100)
  entity_id    String?   @db.Uuid
  changes      Json?
  ip_address   String?   @db.VarChar(64)
  user_agent   String?   @db.VarChar(500)
  trace_id     String?   @db.Uuid
  created_at   DateTime  @default(now()) @db.Timestamptz

  actor        User?     @relation("ActorAuditLogs", fields: [actor_id], references: [id], onDelete: SetNull)

  @@index([entity_type, entity_id])
  @@index([actor_id, created_at])
  @@index([action, created_at])
  @@map("audit_logs")
}

model FollowupNote {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  followup_id String   @db.Uuid
  author_id   String   @db.Uuid
  body        String   @db.Text
  metadata    Json?
  created_at  DateTime @default(now()) @db.Timestamptz

  followup Followup @relation(fields: [followup_id], references: [id], onDelete: Cascade)
  author   User     @relation("AuthoredFollowupNotes", fields: [author_id], references: [id], onDelete: Restrict)

  @@index([followup_id, created_at])
  @@map("followup_notes")
}

model CourseMaster {
  id                  Int              @id @default(autoincrement())
  nameOfCourseAsGroup String           @map("name_of_course_as_group")
  courseFee           Decimal          @map("course_fee") @db.Decimal(10, 2)
  description         String?          @db.Text
  status              CourseStatus     @default(ACTIVE)
  isSystemDefault     Boolean          @default(false) @map("is_system_default")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  // FK: education master
  educationId         Int?             @map("education_id")
  education           EducationMaster? @relation(fields: [educationId], references: [id], onDelete: Restrict)

  // FK: duration master
  durationId          Int?             @map("duration_id")
  duration            DurationMaster?  @relation(fields: [durationId], references: [id], onDelete: Restrict)

  // FK: course name master (normalized name lookup)
  courseNameId        Int              @map("course_name_id")
  courseName          CourseNameMaster @relation(fields: [courseNameId], references: [id], onDelete: Restrict)

  internalPlans       InternalPlan[]

  @@map("course_master")
  @@unique([courseNameId, durationId], name: "course_master_name_duration_unique")
  @@index([status])
  @@index([nameOfCourseAsGroup])
  @@index([educationId])
  @@index([durationId])
  @@index([courseNameId])
}

model EducationMaster {
  id              Int          @id @default(autoincrement())
  name            String       @unique
  code            String       @unique
  description     String?
  status          MasterStatus @default(ACTIVE)
  isSystemDefault Boolean      @default(false) @map("is_system_default")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  courses     CourseMaster[]

  @@map("education_master")
  @@index([status])
  @@index([name])
}

model CourseNameMaster {
  id              Int          @id @default(autoincrement())
  name            String       @unique @db.VarChar(200)
  description     String?      @db.Text
  status          MasterStatus @default(ACTIVE)
  isSystemDefault Boolean      @default(false) @map("is_system_default")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt      @map("updated_at")

  courses CourseMaster[]

  @@map("course_name_master")
  @@index([status])
  @@index([name])
}

model DurationMaster {
  id              Int          @id @default(autoincrement())
  label           String       @unique
  sortOrder       Int          @default(0) @map("sort_order")
  status          MasterStatus @default(ACTIVE)
  isSystemDefault Boolean      @default(false) @map("is_system_default")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  courses   CourseMaster[]

  @@map("duration_master")
  @@index([status])
  @@index([sortOrder])
}

model WebhookDelivery {
  id              Int       @id @default(autoincrement())
  enrollmentId    String?   @map("enrollment_id")
  destinationUrl  String    @map("destination_url")
  method          String    @default("POST")
  requestHeaders  Json?     @map("request_headers")
  requestPayload  Json      @map("request_payload")
  responseStatus  Int?      @map("response_status")
  responseBody    String?   @db.Text @map("response_body")
  errorMessage    String?   @db.Text @map("error_message")
  durationMs      Int?      @map("duration_ms")
  ok              Boolean   @default(false)
  promoCode       String?   @map("promo_code")
  courseMatched   Boolean   @default(false) @map("course_matched")
  source          String    @default("BACKEND")
  sentAt          DateTime  @default(now()) @map("sent_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("webhook_delivery")
  @@index([sentAt(sort: Desc)])
  @@index([enrollmentId])
  @@index([ok])
  @@index([source])
}

model Plan {
  id              Int        @id @default(autoincrement())
  name            String     @db.VarChar(100)
  tier            PlanTier   @unique
  tagline         String?    @db.VarChar(200)
  description     String?    @db.Text
  features        Json       @default("[]")
  highlightLabel  String?    @map("highlight_label") @db.VarChar(50)
  promoCode       String?    @map("promo_code") @db.VarChar(50)
  sortOrder       Int        @default(0) @map("sort_order")
  status          PlanStatus @default(ACTIVE)
  isSystemDefault Boolean    @default(false) @map("is_system_default")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  pricings        PlanPricing[]
  @@map("plans")
  @@index([status, sortOrder])
}

model PlanPricing {
  id              Int        @id @default(autoincrement())
  planId          Int        @map("plan_id")
  // Numeric duration value. Interpreted in `durationUnit` (DAYS or MONTHS).
  // Column name kept as duration_months for migration continuity; it now holds
  // the value in whichever unit the row uses. Decimal(10,2) so fractional
  // durations (e.g. 1.5 Months) are distinct from whole ones (1 Month).
  durationMonths  Decimal    @map("duration_months") @db.Decimal(10, 2)
  durationUnit    String     @default("MONTHS") @map("duration_unit") @db.VarChar(10)
  basePrice       Decimal    @map("base_price") @db.Decimal(10,2)
  discountPercent Decimal    @default(0) @map("discount_percent") @db.Decimal(5,2)
  finalPrice      Decimal    @map("final_price") @db.Decimal(10,2)
  discountLabel   String?    @map("discount_label") @db.VarChar(100)
  // External integration Plan ID. Sent as `planId` in the Sumago provision-user
  // webhook payload. Required on every API write (Joi-validated) but DB column
  // stays nullable so existing pre-feature rows do not block the migration —
  // admin backfills via the UI before payments fire.
  externalPlanId  String?    @unique @map("external_plan_id") @db.VarChar(100)
  status          PlanStatus @default(ACTIVE)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  plan            Plan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  enrollments     Enrollment[] @relation("EnrollmentPlanPricing")
  // Uniqueness is per (plan, duration value, duration unit) so the same number
  // can coexist in different units — e.g. "2 Days" and "2 Months" on one plan.
  @@unique([planId, durationMonths, durationUnit])
  @@map("plan_pricing")
  @@index([status])
}

model InternalPlan {
  id          Int                  @id @default(autoincrement())
  refId       String               @unique @map("ref_id") @db.VarChar(80)
  name        String               @db.VarChar(200)
  duration    InternalPlanDuration
  description String?              @db.Text
  status      InternalPlanStatus   @default(ACTIVE)

  // External integration Plan ID. Sent as `planId` in the Sumago provision-user
  // webhook payload (independent of the legacy `plan` field). Required on every
  // API write (Joi-validated) but DB column stays nullable so existing
  // pre-feature rows do not block the migration — admin backfills via the UI.
  externalPlanId String?           @unique @map("external_plan_id") @db.VarChar(100)

  courseId    Int                  @map("course_id")
  course      CourseMaster         @relation(fields: [courseId], references: [id], onDelete: Restrict)

  // Inverse of Enrollment.internal_plan. Lets admin reports do
  // `internalPlan.enrollments` for "all redemptions for this plan".
  enrollments Enrollment[]         @relation("EnrollmentInternalPlan")

  coupons     Json                 @default("[]")

  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  @@map("internal_plans")
  @@index([status])
  @@index([courseId])
  @@index([name])
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique @db.VarChar(150)
  description String?  @db.VarChar(500)
  created_at  DateTime @default(now()) @db.Timestamptz

  role_permissions RolePermission[]

  @@map("permissions")
}

// Persistent local mirror of users fetched from the Sumago Platform
// Integration API (GET /integrations/get-users). Lets the admin UI
// render instantly from our DB and only re-hits Sumago when explicitly
// resynced. Sync logic lives in sumagoUserSync.service.js.
//
// Natural key is email (Sumago's userId is always null in the
// get-users response, so we cannot use it). The unique index on the
// table is on lower(email), declared in the SQL migration — Prisma
// can't model functional indexes, so we declare the column non-unique
// here and rely on the SQL constraint for uniqueness.
model SumagoUser {
  id                Int       @id @default(autoincrement())
  email             String    @db.VarChar(255)
  firstName         String?   @map("first_name") @db.VarChar(200)
  lastName          String?   @map("last_name")  @db.VarChar(200)
  phoneNumber       String?   @map("phone_number") @db.VarChar(50)

  plan              String?   @db.VarChar(200)
  groupName         String?   @map("group_name") @db.VarChar(200)
  unit              String?   @db.VarChar(200)
  phase             String?   @db.VarChar(200)
  segment           String?   @db.VarChar(200)

  emailStatus       String?   @map("email_status")      @db.VarChar(50)
  onboardingStatus  String?   @map("onboarding_status") @db.VarChar(50)

  planHistory       Json      @default("[]") @map("plan_history")

  organizationCode  String?   @map("organization_code")  @db.VarChar(100)
  tenantTokenHash   String?   @map("tenant_token_hash")  @db.VarChar(64)
  rawPayload        Json      @map("raw_payload")
  contentHash       String    @map("content_hash") @db.Char(64)

  firstSeenAt       DateTime  @default(now()) @map("first_seen_at")  @db.Timestamptz
  lastSyncedAt      DateTime  @default(now()) @map("last_synced_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @map("updated_at")     @db.Timestamptz

  @@map("sumago_users")
  @@index([organizationCode, lastSyncedAt(sort: Desc)])
  @@index([tenantTokenHash])
  @@index([onboardingStatus])
}

// Audit trail of every transactional email the system attempts to send, so the
// admin panel can show "who the mail went to" and offer a resend. Deliberately
// FK-free (enrollment_id / user_id are plain columns): a log row must survive
// even if the related enrollment is soft-deleted or no account exists yet
// (skipped sends). The row is the historical record of an attempt.
model EmailLog {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  to_email      String      @db.VarChar(255)
  type          String      @default("onboarding") @db.VarChar(50)
  status        EmailStatus
  message_id    String?     @db.VarChar(255)
  error         String?     @db.Text
  subject       String?     @db.VarChar(255)
  // Free-text reason for a skipped/failed row (e.g. "account already exists").
  reason        String?     @db.VarChar(255)
  enrollment_id String?     @db.Uuid
  user_id       String?     @db.Uuid
  trace_id      String?     @db.VarChar(64)
  // Who triggered it: null = automatic (enrollment flow); set = admin resend.
  triggered_by  String?     @db.VarChar(255)
  created_at    DateTime    @default(now()) @db.Timestamptz

  @@index([to_email])
  @@index([created_at(sort: Desc)])
  @@index([status])
  @@index([type, created_at(sort: Desc)])
  @@map("email_logs")
}

model RolePermission {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role          Role
  permission_id String     @db.Uuid

  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@unique([role, permission_id])
  @@index([role])
  @@map("role_permissions")
}

// Singleton site-wide branding/settings row (always id = 1). Holds the dynamic
// brand name + uploaded logo shown across the public website, admin panel, and
// transactional emails. Read publicly; written by admin/superadmin only.
model SiteSetting {
  id        Int      @id @default(1)
  brandName String   @default("Kommon School") @map("brand_name") @db.VarChar(150)
  logoUrl   String?  @map("logo_url") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("site_settings")
}

// Lifecycle of a public "Send Us a Message" contact-form submission.
enum ContactSubmissionStatus {
  NEW
  READ
  REPLIED
  SPAM
  ARCHIVED
}

// Public website "Get in Touch" enquiries. The table already exists in the
// database (migration 20260611000000_add_contact_submissions); this model maps
// onto it so the API can read/write it. Field names mirror the snake_case
// columns, so no @map is needed.
model ContactSubmission {
  id          String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String                  @db.VarChar(255)
  email       String                  @db.VarChar(255)
  phone       String?                 @db.VarChar(20)
  message     String                  @db.Text
  status      ContactSubmissionStatus @default(NEW)
  admin_notes String?                 @db.Text
  ip_address  String?
  user_agent  String?
  created_at  DateTime                @default(now()) @db.Timestamptz
  updated_at  DateTime                @updatedAt @db.Timestamptz

  @@map("contact_submissions")
  @@index([status])
  @@index([created_at])
}
