{
  "name": "kommon-school-backend",
  "version": "1.0.0",
  "description": "Kommon School Student Enrollment & Payment Platform — MVP Backend",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "start:prod": "pm2 start ecosystem.config.js --env production",
    "test": "node --test --test-reporter=spec \"src/tests/unit/*.test.js\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "db:seed": "node src/prisma/seed.js"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma",
    "seed": "node src/prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "axios": "^1.7.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.8.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.10",
    "opossum": "^8.1.4",
    "prisma": "^5.14.0",
    "razorpay": "^2.9.2",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  }
}
