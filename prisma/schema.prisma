// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
  PARENT
  // New roles for enrollment/payment/CRM system
  ADMIN
  MARKETING
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

enum StudentStatus {
  ENROLLED
  GRADUATED
  SUSPENDED
  WITHDRAWN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// ── Enrollment Enums ──────────────────────────
enum EnrollmentRole {
  STUDENT
  FRESH_GRADUATE
  WORKING_PROFESSIONAL
  CAREER_SWITCHER
}

enum EducationLevel {
  SCHOOL
  JR_COLLEGE
  UNDERGRADUATE
  GRADUATE
  POST_GRADUATE
  DOCTORATE
  OTHER
}

enum PlacementReadiness {
  BEGINNER
  INTERMEDIATE
  READY_FOR_INTERVIEW
}

enum LeadSource {
  SOCIAL_MEDIA
  COLLEGE
  FRIEND
  GOOGLE
  OTHER
}

enum EnrollmentStatus {
  PENDING
  PAYMENT_PENDING
  PAYMENT_COMPLETED
  CANCELLED
}

// ── Payment Enums ─────────────────────────────
enum PaymentStatus {
  INITIATED
  CREATED
  IN_PROGRESS
  PENDING
  SUCCESS
  FAILED
  PARTIAL
  REFUNDED
  EXPIRED
}

enum PaymentFailureType {
  USER_CANCELLED
  PAYMENT_FAILED
  GATEWAY_ERROR
  NETWORK_ERROR
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

enum LedgerSource {
  PAYMENT
  REFUND
  ADJUSTMENT
}

// ── CRM / FollowUp Enums ──────────────────────
enum FollowUpStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  CALLBACK
  PAYMENT_PENDING
  CONVERTED
  NOT_INTERESTED
  CLOSED
}

enum FollowUpPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InteractionType {
  CALL
  WHATSAPP
  EMAIL
}

enum InteractionOutcome {
  CONNECTED
  NOT_CONNECTED
  NOT_REACHABLE
  SWITCHED_OFF
  BUSY
  WRONG_NUMBER
  VOICEMAIL
  CALLBACK_REQUESTED
  INTERESTED
  NOT_INTERESTED
  CONVERTED
}

enum UserResponse {
  VERY_INTERESTED
  INTERESTED
  NEUTRAL
  NOT_INTERESTED
  DO_NOT_CONTACT
}

// ── External API Enums ────────────────────────
enum SyncStatus {
  PENDING
  SUCCESS
  FAILED
  DEAD_LETTER
}

// ─────────────────────────────────────────────
// TENANT (School / Organization)
// ─────────────────────────────────────────────

model Tenant {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  domain      String?      @unique
  status      TenantStatus @default(TRIAL)
  logoUrl     String?
  address     String?
  phone       String?
  email       String?
  timezone    String       @default("UTC")
  locale      String       @default("en")
  settings    Json         @default("{}")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  // Relations
  users          User[]
  students       Student[]
  refreshTokens  RefreshToken[]

  @@index([slug])
  @@index([domain])
  @@index([status])
  @@index([deletedAt])
  @@map("tenants")
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  tenantId          String?
  email             String
  passwordHash      String
  firstName         String
  lastName          String
  role              UserRole  @default(STUDENT)
  phone             String?
  avatarUrl         String?
  isEmailVerified   Boolean   @default(false)
  isActive          Boolean   @default(true)
  lastLoginAt       DateTime?
  passwordChangedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  tenant        Tenant?        @relation(fields: [tenantId], references: [id])
  refreshTokens RefreshToken[]
  student       Student?
  assignedFollowUps FollowUp[] @relation("AssignedFollowUps")

  // Super admins have no tenant (tenantId = null)
  // All other roles must have a tenantId
  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([email])
  @@index([tenantId, role])
  @@index([deletedAt])
  @@map("users")
}

// ─────────────────────────────────────────────
// REFRESH TOKEN
// ─────────────────────────────────────────────

model RefreshToken {
  id          String    @id @default(cuid())
  userId      String
  tenantId    String?
  tokenHash   String    @unique
  family      String    // token rotation family (detect reuse)
  isRevoked   Boolean   @default(false)
  expiresAt   DateTime
  userAgent   String?
  ipAddress   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@index([tokenHash])
  @@index([family])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// STUDENT (existing school management model)
// ─────────────────────────────────────────────

model Student {
  id             String        @id @default(cuid())
  tenantId       String
  userId         String        @unique
  studentCode    String
  firstName      String
  lastName       String
  dateOfBirth    DateTime?
  gender         Gender?
  grade          String?
  section        String?
  enrollmentDate DateTime      @default(now())
  status         StudentStatus @default(ENROLLED)
  guardianName   String?
  guardianPhone  String?
  guardianEmail  String?
  address        String?
  notes          String?
  metadata       Json          @default("{}")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([tenantId, studentCode])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, grade])
  @@index([userId])
  @@index([deletedAt])
  @@map("students")
}

// ─────────────────────────────────────────────
// ENROLLMENT (marketing / lead capture)
// ─────────────────────────────────────────────

model Enrollment {
  id              String          @id @default(cuid())
  enrollmentId    String          @unique  // ENR-YYYYMMDD-XXXXXX
  idempotencyKey  String          @unique
  name            String
  phone           String
  email           String
  role            EnrollmentRole
  education       EducationLevel?
  readiness       PlacementReadiness?
  source          LeadSource?
  status          EnrollmentStatus @default(PENDING)
  tenantId        String?
  metadata        Json            @default("{}")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  payments  Payment[]
  followUp  FollowUp?

  // Deduplicate by email OR phone (enforced at service layer)
  @@index([email])
  @@index([phone])
  @@index([enrollmentId])
  @@index([status])
  @@index([createdAt])
  @@map("enrollments")
}

// ─────────────────────────────────────────────
// RAZORPAY CONFIGURATION
// ─────────────────────────────────────────────

model RazorpayConfig {
  id          String   @id @default(cuid())
  name        String   // label e.g. "Production", "Test"
  keyId       String   // encrypted at rest recommended
  keySecret   String   // encrypted at rest — NEVER log
  webhookSecret String // for signature verification
  isActive    Boolean  @default(false)
  mode        String   @default("test") // "test" | "live"
  tenantId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Only one config can be active per tenant (null = global)
  @@index([isActive])
  @@index([tenantId])
  @@map("razorpay_configs")
}

// ─────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────

model Payment {
  id                String         @id @default(cuid())
  enrollmentId      String
  razorpayOrderId   String?        @unique
  razorpayPaymentId String?        @unique
  razorpaySignature String?
  status            PaymentStatus  @default(INITIATED)
  failureType       PaymentFailureType?
  failureReason     String?

  // Financial breakdown — all amounts in paise (integer)
  currency          String         @default("INR")
  baseAmount        Int            // paise
  taxAmount         Int            @default(0) // paise
  discount          Int            @default(0) // paise
  finalAmount       Int            // paise = base + tax - discount
  paidAmount        Int            @default(0) // paise
  remainingAmount   Int            @default(0) // paise

  // Attempt tracking
  retryCount        Int            @default(0)
  startedAt         DateTime?
  lastHeartbeatAt   DateTime?
  clientConfirmedAt DateTime?
  expiresAt         DateTime?      // TTL for pending payments

  // Idempotency
  idempotencyKey    String         @unique

  // Status history (JSON array for audit)
  statusHistory     Json           @default("[]")

  // Payment attempt metadata
  attemptMetadata   Json           @default("{}")

  // Razorpay order receipt
  receipt           String?

  tenantId          String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Relations
  enrollment        Enrollment     @relation(fields: [enrollmentId], references: [id])
  auditLogs         PaymentAuditLog[]
  ledgerEntries     LedgerEntry[]
  webhookEvents     WebhookEvent[]
  externalApiLogs   ExternalApiLog[]

  @@index([enrollmentId])
  @@index([status])
  @@index([razorpayOrderId])
  @@index([razorpayPaymentId])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([tenantId])
  @@map("payments")
}

// ─────────────────────────────────────────────
// PAYMENT AUDIT LOG
// ─────────────────────────────────────────────

model PaymentAuditLog {
  id          String   @id @default(cuid())
  paymentId   String
  fromStatus  String?
  toStatus    String
  reason      String?
  actor       String?  // user id or "system" or "webhook"
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  payment     Payment  @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@index([createdAt])
  @@map("payment_audit_logs")
}

// ─────────────────────────────────────────────
// LEDGER ENTRY (double-entry)
// ─────────────────────────────────────────────

model LedgerEntry {
  id            String           @id @default(cuid())
  paymentId     String
  enrollmentId  String?
  type          LedgerEntryType  // DEBIT | CREDIT
  source        LedgerSource     // PAYMENT | REFUND | ADJUSTMENT
  amount        Int              // paise
  currency      String           @default("INR")
  description   String?
  reference     String?          // razorpayPaymentId or razorpayRefundId
  balanceBefore Int              @default(0) // running balance snapshot
  balanceAfter  Int              @default(0)
  metadata      Json             @default("{}")
  createdAt     DateTime         @default(now())

  payment       Payment          @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@index([enrollmentId])
  @@index([type])
  @@index([source])
  @@index([createdAt])
  @@map("ledger_entries")
}

// ─────────────────────────────────────────────
// WEBHOOK EVENT
// ─────────────────────────────────────────────

model WebhookEvent {
  id              String   @id @default(cuid())
  provider        String   @default("razorpay")
  eventId         String   // Razorpay webhook event id
  eventType       String   // e.g. "payment.captured"
  paymentId       String?
  rawPayload      Json     // full webhook body
  payloadHash     String   // sha256 of raw body for integrity
  processed       Boolean  @default(false)
  processedAt     DateTime?
  error           String?
  retryCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payment         Payment? @relation(fields: [paymentId], references: [id])

  // Unique per provider+eventId to prevent duplicate processing
  @@unique([provider, eventId])
  @@index([processed])
  @@index([paymentId])
  @@index([eventType])
  @@index([createdAt])
  @@map("webhook_events")
}

// ─────────────────────────────────────────────
// IDEMPOTENCY KEYS
// ─────────────────────────────────────────────

model IdempotencyKey {
  id              String   @id @default(cuid())
  key             String   @unique
  requestHash     String   // sha256 of request body
  responseStatus  Int?
  responseBody    Json?    // cached response
  status          String   @default("PENDING") // PENDING | COMPLETED | FAILED
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

// ─────────────────────────────────────────────
// EXTERNAL API LOG
// ─────────────────────────────────────────────

model ExternalApiLog {
  id              String     @id @default(cuid())
  paymentId       String?
  enrollmentId    String?
  endpoint        String
  method          String     @default("POST")
  requestBody     Json?
  responseStatus  Int?
  responseBody    Json?
  syncStatus      SyncStatus @default(PENDING)
  retryCount      Int        @default(0)
  nextRetryAt     DateTime?
  lastAttemptAt   DateTime?
  error           String?
  duration        Int?       // ms
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  payment         Payment?   @relation(fields: [paymentId], references: [id])

  @@index([syncStatus])
  @@index([paymentId])
  @@index([enrollmentId])
  @@index([nextRetryAt])
  @@index([createdAt])
  @@map("external_api_logs")
}

// ─────────────────────────────────────────────
// FOLLOW-UP (CRM)
// ─────────────────────────────────────────────

model FollowUp {
  id              String           @id @default(cuid())
  enrollmentId    String           @unique
  assignedToId    String?
  status          FollowUpStatus   @default(NEW)
  priority        FollowUpPriority @default(MEDIUM)
  callAttempts    Int              @default(0)

  // Tracking
  nextFollowUpAt  DateTime?
  lastActivityAt  DateTime?
  lastContactAt   DateTime?        // last successful contact (CALL/WHATSAPP/EMAIL with CONNECTED-class outcome)
  convertedAt     DateTime?
  closedAt        DateTime?
  dueAt           DateTime?        // set by reminder cron

  // Tags
  tags            String[]         @default([])

  // Payment intent snapshot
  paymentIntent   Json             @default("{}")

  // Notes and interactions as JSON arrays (flexible for rapid iteration)
  notes           Json             @default("[]")
  interactions    Json             @default("[]")

  // History / status change audit
  history         Json             @default("[]")

  tenantId        String?
  metadata        Json             @default("{}")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  enrollment      Enrollment       @relation(fields: [enrollmentId], references: [id])
  assignedTo      User?            @relation("AssignedFollowUps", fields: [assignedToId], references: [id])

  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([nextFollowUpAt])
  @@index([lastActivityAt])
  @@index([dueAt])
  @@index([tenantId])
  @@index([createdAt])
  @@map("follow_ups")
}
